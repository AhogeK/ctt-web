# https://editorconfig.org

# Top-most config file, stop searching parent directories
root = true

# Default for all files
[*]
charset = utf-8
# Force LF (Unix), prevent CRLF pollution from Windows
end_of_line = lf
indent_style = space
indent_size = 2
# POSIX standard: newline at end of file
insert_final_newline = true
# Remove trailing whitespace
trim_trailing_whitespace = true

# Markdown exception: allow trailing spaces for line breaks
[*.md]
trim_trailing_whitespace = false